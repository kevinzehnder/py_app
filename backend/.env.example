# Set false to run without MongoDB (disables the items example + DB lifecycle)
MONGO_ENABLED=true
MONGO_CONNECTION_STRING=mongodb://root:password@localhost:27017/
MONGO_DB_NAME=admin_template
JWT_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
LOG_FORMAT=console
ENVIRONMENT=dev

# Demo user — override to change credentials without touching code
DEMO_EMAIL=admin@example.com
DEMO_PASSWORD=secret
DEMO_NAME=Admin
DEMO_ROLE=admin

# Azure AI Foundry / Azure OpenAI (ai module) — requires the `ai` extra: uv sync --extra ai
# Preferred: use the v1 endpoint and leave API version blank.
AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
